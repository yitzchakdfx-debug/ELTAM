# ============================================================
# DFX_ate environment configuration  (SINGLE SOURCE OF TRUTH)
# ------------------------------------------------------------
# Copy this file to ".env" placed NEXT TO DFX_Tester.exe
# (or at the repo root during development). Do NOT commit .env.
# Non-secret keys are optional; password keys must be set in .env.
# ============================================================

# --- Secrets ---
LOG_ENCRYPTION_PASSWORD=XXX
ADMIN_REPORT_PASSWORD=XXX

# --- Default admin seed (applied only on first database creation) ---
DEFAULT_ADMIN_USERNAME=lior
DEFAULT_ADMIN_PASSWORD=XXX
DEFAULT_ADMIN_EMPLOYEE_ID=0000

# --- Application identity ---
APP_VERSION=0.1.0-Beta
TESTER_SERIAL_NUMBER=ATE-DFX-001

# --- Feature flags (true/false) ---
SHOW_LIVE_MONITOR=true
SHOW_SEARCH_BAR=false

# --- Pre-test UUT options (comma-separated) ---
UUT_TYPES=Power main,Power Ctrl DSP,Demo UUT
